<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.RukuxinxiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.RukuxinxiEntity" id="rukuxinxiMap">
        <result property="dinghuoid" column="dinghuoid"/>
        <result property="fuzhuangbianhao" column="fuzhuangbianhao"/>
        <result property="fuzhuangmingcheng" column="fuzhuangmingcheng"/>
        <result property="shangpinfenlei" column="shangpinfenlei"/>
        <result property="gongyingshangmingcheng" column="gongyingshangmingcheng"/>
        <result property="gongyingshangid" column="gongyingshangid"/>
        <result property="lianxidianhua" column="lianxidianhua"/>
        <result property="fuzhuangtupian" column="fuzhuangtupian"/>
        <result property="yanse" column="yanse"/>
        <result property="chicun" column="chicun"/>
        <result property="fuzhuangkucun" column="fuzhuangkucun"/>
        <result property="zhanghao" column="zhanghao"/>
        <result property="xingming" column="xingming"/>
        <result property="rukushijian" column="rukushijian"/>
        <result property="yanshoushuoming" column="yanshoushuoming"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.RukuxinxiVO" >
		SELECT * FROM rukuxinxi  rukuxinxi         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.RukuxinxiVO" >
		SELECT  rukuxinxi.* FROM rukuxinxi  rukuxinxi 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.RukuxinxiView" >

		SELECT  rukuxinxi.* FROM rukuxinxi  rukuxinxi 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.RukuxinxiView" >
		SELECT * FROM rukuxinxi  rukuxinxi <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM rukuxinxi
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM rukuxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM rukuxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM rukuxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM rukuxinxi
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>




</mapper>
