","components","created","getCurDate","methods","download","file","window","open","concat","init","_this","info","logistics","obj","$storage","getObj","o","$http","url","get","method","then","_ref","code","json","$message","error","msg","_this2","_ref2","reg","RegExp","onSubmit","_this3","_asyncToGenerator","_regenerator","m","_callee3","objcross","w","_context3","n","$refs","validate","_ref3","_callee2","valid","statusColumnName","statusColumnValue","table","_context2","startsWith","_ref4","_ref6","_callee","_ref5","_context","message","duration","onClose","parent","showFlag","addOrUpdateFlag","shangpinfenleiCrossAddOrUpdateFlag","search","contentStyleChange","a","_x2","apply","arguments","_x","getUUID","Date","getTime","back"],"sources":["src/views/modules/shangpinfenlei/add-or-update.vue"],"sourcesContent":["<template>\r\n\t<div class=\"addEdit-block\">\r\n\t\t<el-form\r\n\t\t\tclass=\"add-update-preview\"\r\n\t\t\tref=\"ruleForm\"\r\n\t\t\t:model=\"ruleForm\"\r\n\t\t\t:rules=\"rules\"\r\n\t\t\tlabel-width=\"180px\"\r\n\t\t>\r\n\t\t\t<template >\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"商品分类\" prop=\"shangpinfenlei\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.shangpinfenlei\" placeholder=\"商品分类\" clearable  :readonly=\"ro.shangpinfenlei\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"商品分类\" prop=\"shangpinfenlei\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.shangpinfenlei\" placeholder=\"商品分类\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"date\" v-if=\"type!='info'\" label=\"添加时间\" prop=\"tianjiashijian\" >\r\n\t\t\t\t\t<el-date-picker\r\n\t\t\t\t\t\tformat=\"yyyy 年 MM 月 dd 日\"\r\n\t\t\t\t\t\tvalue-format=\"yyyy-MM-dd\"\r\n\t\t\t\t\t\tv-model=\"ruleForm.tianjiashijian\" \r\n\t\t\t\t\t\ttype=\"date\"\r\n\t\t\t\t\t\t:readonly=\"ro.tianjiashijian\"\r\n\t\t\t\t\t\tplaceholder=\"添加时间\"\r\n\t\t\t\t\t></el-date-picker> \r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"input\" v-else-if=\"ruleForm.tianjiashijian\" label=\"添加时间\" prop=\"tianjiashijian\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.tianjiashijian\" placeholder=\"添加时间\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t</template>\r\n\t\t\t<el-form-item class=\"btn\">\r\n\t\t\t\t<el-button class=\"btn3\"  v-if=\"type!='info'\" type=\"success\" @click=\"onSubmit\">\r\n\t\t\t\t\t<span class=\"icon iconfont icon-xihuan\"></span>\r\n\t\t\t\t\t提交\r\n\t\t\t\t</el-button>\r\n\t\t\t\t<el-button class=\"btn4\" v-if=\"type!='info'\" type=\"success\" @click=\"back()\">\r\n\t\t\t\t\t<span class=\"icon iconfont icon-xihuan\"></span>\r\n\t\t\t\t\t取消\r\n\t\t\t\t</el-button>\r\n\t\t\t\t<el-button class=\"btn5\" v-if=\"type=='info'\" type=\"success\" @click=\"back()\">\r\n\t\t\t\t\t<span class=\"icon iconfont icon-xihuan\"></span>\r\n\t\t\t\t\t返回\r\n\t\t\t\t</el-button>\r\n\t\t\t</el-form-item>\r\n\t\t</el-form>\r\n    \r\n\r\n\t</div>\r\n</template>\r\n<script>\r\n\texport default {\r\n\t\tdata() {\r\n\t\t\treturn {\r\n\t\t\t\tid: '',\r\n\t\t\t\ttype: '',\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\tro:{\r\n\t\t\t\t\tshangpinfenlei : false,\r\n\t\t\t\t\ttianjiashijian : false,\r\n\t\t\t\t},\r\n\t\t\t\r\n\t\t\t\truleForm: {\r\n\t\t\t\t\tshangpinfenlei: '',\r\n\t\t\t\t\ttianjiashijian: '',\r\n\t\t\t\t},\r\n\t\t\r\n\r\n\t\t\t\trules: {\r\n\t\t\t\t\tshangpinfenlei: [\r\n\t\t\t\t\t],\r\n\t\t\t\t\ttianjiashijian: [\r\n\t\t\t\t\t],\r\n\t\t\t\t},\r\n\t\t\t};\r\n\t\t},\r\n\t\tprops: [\"parent\"],\r\n\t\tcomputed: {\r\n\r\n\r\n\r\n\t\t},\r\n\t\tcomponents: {\r\n\t\t},\r\n\t\tcreated() {\r\n\t\t\tthis.ruleForm.tianjiashijian = this.getCurDate()\r\n\t\t},\r\n\t\tmethods: {\r\n\t\t\t// 下载\r\n\t\t\tdownload(file){\r\n\t\t\t\twindow.open(`${file}`)\r\n\t\t\t},\r\n\t\t\t// 初始化\r\n\t\t\tinit(id,type) {\r\n\t\t\t\tif (id) {\r\n\t\t\t\t\tthis.id = id;\r\n\t\t\t\t\tthis.type = type;\r\n\t\t\t\t}\r\n\t\t\t\tif(this.type=='info'||this.type=='else'){\r\n\t\t\t\t\tthis.info(id);\r\n\t\t\t\t}else if(this.type=='logistics'){\r\n\t\t\t\t\tthis.logistics=false;\r\n\t\t\t\t\tthis.info(id);\r\n\t\t\t\t}else if(this.type=='cross'){\r\n\t\t\t\t\tvar obj = this.$storage.getObj('crossObj');\r\n\t\t\t\t\tfor (var o in obj){\r\n\t\t\t\t\t\tif(o=='shangpinfenlei'){\r\n\t\t\t\t\t\t\tthis.ruleForm.shangpinfenlei = obj[o];\r\n\t\t\t\t\t\t\tthis.ro.shangpinfenlei = true;\r\n\t\t\t\t\t\t\tcontinue;\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t\tif(o=='tianjiashijian'){\r\n\t\t\t\t\t\t\tthis.ruleForm.tianjiashijian = obj[o];\r\n\t\t\t\t\t\t\tthis.ro.tianjiashijian = true;\r\n\t\t\t\t\t\t\tcontinue;\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t\t// 获取用户信息\r\n\t\t\t\tthis.$http({\r\n\t\t\t\t\turl: `${this.$storage.get('sessionTable')}/session`,\r\n\t\t\t\t\tmethod: \"get\"\r\n\t\t\t\t}).then(({ data }) => {\r\n\t\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\t\tvar json = data.data;\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tthis.$message.error(data.msg);\r\n\t\t\t\t\t}\r\n\t\t\t\t});\r\n\t\t\t\r\n\t\t\t},\r\n\t\t\t// 多级联动参数\r\n\r\n\t\t\tinfo(id) {\r\n\t\t\t\tthis.$http({\r\n\t\t\t\t\turl: `shangpinfenlei/info/${id}`,\r\n\t\t\t\t\tmethod: \"get\"\r\n\t\t\t\t}).then(({ data }) => {\r\n\t\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\t\tthis.ruleForm = data.data;\r\n\t\t\t\t\t\t//解决前台上传图片后台不显示的问题\r\n\t\t\t\t\t\tlet reg=new RegExp('../../../upload','g')//g代表全部\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tthis.$message.error(data.msg);\r\n\t\t\t\t\t}\r\n\t\t\t\t});\r\n\t\t\t},\r\n\r\n\t\t\t// 提交\r\n\t\t\tasync onSubmit() {\r\n\t\t\t\t\tvar objcross = this.$storage.getObj('crossObj');\r\n\t\t\t\t\tawait this.$refs[\"ruleForm\"].validate(async valid => {\r\n\t\t\t\t\t\tif (valid) {\r\n\t\t\t\t\t\t\tif(this.type=='cross'){\r\n\t\t\t\t\t\t\t\tvar statusColumnName = this.$storage.get('statusColumnName');\r\n\t\t\t\t\t\t\t\tvar statusColumnValue = this.$storage.get('statusColumnValue');\r\n\t\t\t\t\t\t\t\tif(statusColumnName!='') {\r\n\t\t\t\t\t\t\t\t\tvar obj = this.$storage.getObj('crossObj');\r\n\t\t\t\t\t\t\t\t\tif(statusColumnName && !statusColumnName.startsWith(\"[\")) {\r\n\t\t\t\t\t\t\t\t\t\tfor (var o in obj){\r\n\t\t\t\t\t\t\t\t\t\t\tif(o==statusColumnName){\r\n\t\t\t\t\t\t\t\t\t\t\t\tobj[o] = statusColumnValue;\r\n\t\t\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t\t\tvar table = this.$storage.get('crossTable');\r\n\t\t\t\t\t\t\t\t\t\tawait this.$http({\r\n\t\t\t\t\t\t\t\t\t\t\turl: `${table}/update`,\r\n\t\t\t\t\t\t\t\t\t\t\tmethod: \"post\",\r\n\t\t\t\t\t\t\t\t\t\t\tdata: obj\r\n\t\t\t\t\t\t\t\t\t\t}).then(({ data }) => {});\r\n\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\r\n\t\t\t\t\t\t\tawait this.$http({\r\n\t\t\t\t\t\t\t\turl: `shangpinfenlei/${!this.ruleForm.id ? \"save\" : \"update\"}`,\r\n\t\t\t\t\t\t\t\tmethod: \"post\",\r\n\t\t\t\t\t\t\t\tdata: this.ruleForm\r\n\t\t\t\t\t\t\t}).then(async ({ data }) => {\r\n\t\t\t\t\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\t\t\t\t\tthis.$message({\r\n\t\t\t\t\t\t\t\t\t\tmessage: \"操作成功\",\r\n\t\t\t\t\t\t\t\t\t\ttype: \"success\",\r\n\t\t\t\t\t\t\t\t\t\tduration: 1500,\r\n\t\t\t\t\t\t\t\t\t\tonClose: () => {\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.showFlag = true;\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.addOrUpdateFlag = false;\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.shangpinfenleiCrossAddOrUpdateFlag = false;\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.search();\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.contentStyleChange();\r\n\t\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t\t});\r\n\t\t\t\t\t\t\t\t} else {\r\n\t\t\t\t\t\t\t\t\tthis.$message.error(data.msg);\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t});\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t});\r\n\t\t\t},\r\n\t\t\t// 获取uuid\r\n\t\t\tgetUUID () {\r\n\t\t\t\treturn new Date().getTime();\r\n\t\t\t},\r\n\t\t\t// 返回\r\n\t\t\tback() {\r\n\t\t\t\tthis.parent.showFlag = true;\r\n\t\t\t\tthis.parent.addOrUpdateFlag = false;\r\n\t\t\t\tthis.parent.shangpinfenleiCrossAddOrUpdateFlag = false;\r\n\t\t\t\tthis.parent.contentStyleChange();\r\n